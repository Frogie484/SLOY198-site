{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/admin.html"
    },
    {
      "source": "/api/admin/login",
      "destination": "/api/admin/auth?action=login"
    },
    {
      "source": "/api/admin/logout",
      "destination": "/api/admin/auth?action=logout"
    },
    {
      "source": "/api/admin/session",
      "destination": "/api/admin/auth?action=session"
    },
    {
      "source": "/api/admin/schedule",
      "destination": "/api/admin/booking?action=schedule"
    },
    {
      "source": "/api/admin/bookings/:id",
      "destination": "/api/admin/booking?action=booking&id=:id"
    },
    {
      "source": "/api/admin/slots",
      "destination": "/api/admin/slot?action=slots"
    },
    {
      "source": "/api/admin/slots/:id",
      "destination": "/api/admin/slot?action=slot&id=:id"
    },
    {
      "source": "/api/admin/courses",
      "destination": "/api/admin/education?action=courses"
    },
    {
      "source": "/api/admin/courses/:id",
      "destination": "/api/admin/education?action=course&id=:id"
    },
    {
      "source": "/api/admin/course",
      "destination": "/api/admin/education?action=course"
    },
    {
      "source": "/api/admin/lessons",
      "destination": "/api/admin/content?action=lessons"
    },
    {
      "source": "/api/admin/lessons/:id",
      "destination": "/api/admin/content?action=lesson&id=:id"
    },
    {
      "source": "/api/admin/lesson",
      "destination": "/api/admin/content?action=lesson"
    },
    {
      "source": "/api/admin/course-access",
      "destination": "/api/admin/content?action=course-access"
    }
  ]
}
